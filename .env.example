# CRE Asset Management Dashboard — Environment Variables
# Copy this file to .env and fill in your values

# App Settings
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# Database (SQLite for MVP)
DB_PATH=./data/cre_dashboard.db

# File Storage
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
EXPORT_DIR=./data/exports

# Future: Supabase (leave blank for MVP)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Future: Auth
JWT_SECRET=
JWT_EXPIRY_HOURS=24
